datasource db {
  provider = "mysql"
}

generator companyClient {
  provider = "prisma-client-js"
  output   = "../packages/db-company/generated/client"
}

generator crmClient {
  provider = "prisma-client-js"
  output   = "../packages/db-crm/generated/client"
}

enum Role {
  USER
  MANAGER
  ADMIN
}

model Company {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique @default(cuid())
  subscriptionType String @default("STARTER_FREE")
  stripeCustomerId String? @unique
  stripeSubscriptionId String? @unique
  stripePriceId String?
  stripeSubscriptionStatus String?
  stripePurchasedAt DateTime?
  stripeCurrentPeriodStart DateTime?
  stripeCurrentPeriodEnd DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  clients           Client[]
  projects          Project[]
  kahierConnection  KahierConnection?
  kahierLinkTokens  KahierLinkToken[]
}

model KahierConnection {
  id                      String   @id @default(cuid())
  companyId               String   @unique
  kahierEstablishmentId   Int
  kahierEstablishmentName String
  kahierApiKey            String?
  kahierZoneId            Int?
  kahierZoneName          String?
  kahierUserId            Int?
  kahierUserLabel         String?
  linkedByUserId          String?
  linkedAt                DateTime @default(now())
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([kahierEstablishmentId])
  @@index([kahierZoneId])
}

model KahierLinkToken {
  id                      String   @id @default(cuid())
  companyId               String
  codeHash                String   @unique
  codePreview             String
  expiresAt               DateTime
  consumedAt              DateTime?
  createdByUserId         String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  kahierEstablishmentId   Int?
  kahierEstablishmentName String?
  kahierZoneId            Int?
  kahierZoneName          String?
  kahierUserId            Int?
  kahierUserLabel         String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, expiresAt])
  @@index([companyId, consumedAt])
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  PROSPECT
}

enum ClientSegment {
  TPE
  PME
  ETI
  GE
  OTHER
}

enum RevenueSource {
  REFERRAL
  OUTBOUND
  ADS
  PARTNER
  UPSELL
  OTHER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      Role     @default(USER)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientsOwned              Client[]            @relation("UserToClientOwner")
  clientAssignments         ClientOwner[]
  clientInteractions        ClientInteraction[]
  collaboratingInteractions ClientInteraction[] @relation("InteractionCollaborators")
  uploadedClientDocuments   ClientDocument[]
  projectsOwned             Project[]
}

model Client {
  id           String        @id @default(cuid())
  name         String
  status       ClientStatus  @default(PROSPECT)
  segment      ClientSegment @default(OTHER)
  revenueSource RevenueSource?
  location     String?
  companyId    String?
  ownerId      String?
  notes        String?
  primaryEmail String?
  primaryPhone String?
  emails       Json?
  phones       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner        User?               @relation("UserToClientOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  company      Company?            @relation(fields: [companyId], references: [id], onDelete: SetNull)
  owners       ClientOwner[]
  contacts     ClientContact[]
  interactions ClientInteraction[]
  documents    ClientDocument[]
  projects     Project[]

  @@index([status])
  @@index([segment])
  @@index([location])
  @@index([ownerId])
  @@index([companyId])
  @@index([name])
  @@index([primaryEmail])
  @@index([primaryPhone])
}

model ClientOwner {
  id       String @id @default(cuid())
  clientId String
  userId   String

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clientId, userId])
  @@index([clientId])
  @@index([userId])
}

model ClientContact {
  id        String  @id @default(cuid())
  clientId  String
  firstName String
  lastName  String
  email     String?
  phone     String?
  emails    Json?
  phones    Json?
  role      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([email])
}

model ClientInteraction {
  id           String    @id @default(cuid())
  clientId     String
  userId       String?
  type         String
  summary      String?
  occurredAt   DateTime  @default(now())
  meetingStart DateTime?
  meetingEnd   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client        Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user          User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  collaborators User[] @relation("InteractionCollaborators")

  @@index([clientId, occurredAt])
  @@index([userId])
}

model ClientDocument {
  id         String  @id @default(cuid())
  clientId   String
  uploaderId String?
  fileName   String
  s3Key      String
  mimeType   String?
  size       Int?

  createdAt DateTime @default(now())

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  uploader User?  @relation(fields: [uploaderId], references: [id], onDelete: SetNull)

  @@index([clientId, createdAt])
  @@index([uploaderId])
}

enum ProjectStatus {
  DRAFT
  IN_PROGRESS
  ON_HOLD
  COMPLETED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
}

model Project {
  id          String          @id @default(cuid())
  name        String
  reference   String?
  description String?         @db.Text
  context     String?         @db.Text
  goals       String?         @db.Text
  deliverables String?        @db.Text
  successMetrics String?      @db.Text
  risks       String?         @db.Text
  notes       String?         @db.Text
  status      ProjectStatus   @default(DRAFT)
  priority    ProjectPriority @default(MEDIUM)
  progress    Int             @default(0)
  budgetAmount Int?
  revenueAmount Int?
  costAmount Int?
  invoicedAmount Int?
  receivedAmount Int?
  billingMode String?
  startDate   DateTime?
  endDate     DateTime?
  companyId   String
  clientId    String?
  ownerId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client  Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  owner   User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([clientId])
  @@index([ownerId])
  @@index([status])
  @@index([priority])
  @@index([name])
  @@index([endDate])
}
