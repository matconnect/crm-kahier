{
  "name": "crm-kahier",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate:company": "pnpm --dir apps/company-service exec prisma generate",
    "db:generate:crm": "pnpm --dir apps/crm-service exec prisma generate",
    "db:generate": "pnpm db:generate:company && pnpm db:generate:crm",
    "postinstall": "pnpm db:generate",
    "db:split-services": "node scripts/split-service-dbs.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "prettier": "^3.7.4",
    "prisma": "^7.4.1",
    "turbo": "^2.7.2",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "mariadb": "^3.4.5"
  }
}
