{
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "app/src",
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "incremental": false,
    "isolatedModules": true,
    "lib": ["es2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "Bundler",
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "allowJs": false,
    "noEmit": false
  },
  "include": ["app/src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
